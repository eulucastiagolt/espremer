# Resend (Email)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=Espremer <noreply@your-domain.com>
CONTACT_EMAIL=seu@email.com

# hCaptcha (Anti-spam)
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=0x0000000000000000000000000000000000000000
HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database (Prisma)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Public URL used by NextAuth and links sent by email
NEXTAUTH_URL=https://your-site.netlify.app
NEXTAUTH_SECRET=generate-a-long-random-secret

# Setup (desativar após criar super admin)
SETUP_SECRET=your-secret-here
